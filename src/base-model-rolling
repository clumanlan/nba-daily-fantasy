with mlflow.start_run() as run:
    
    full_data = active_playergamelog_processed[['SEASON_ID', 'Player_ID', 'GAME_DATE','fp'] + base_cols]
    full_data.dropna(axis=0, inplace=True)

    train = full_data[full_data['SEASON_ID'] < 22019]
